# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ALLOWED_USER_IDS=123456789

# OpenRouter LLM
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL_SIMPLE=deepseek/deepseek-chat-v3-0324
OPENROUTER_MODEL_MODERATE=deepseek/deepseek-v3.2
OPENROUTER_MODEL_COMPLEX=anthropic/claude-sonnet-4.6

# Agent
AGENT_MAX_ITERATIONS=10
SESSION_TIMEOUT_MINUTES=30

# Google Workspace (requires: npm i -g @googleworkspace/cli && gws auth login)
GWS_DRIVE_ENABLED=true
GWS_DRIVE_FOLDER_IDS=              # Comma-separated folder IDs to restrict access (empty = all)
GWS_SHEETS_ENABLED=false
GWS_GMAIL_ENABLED=false
GWS_CALENDAR_ENABLED=false

# Bitbucket Cloud (Atlassian API Token)
BITBUCKET_EMAIL=tu-email@ejemplo.com
BITBUCKET_API_TOKEN=tu-atlassian-api-token
BITBUCKET_WORKSPACE=tu-workspace
BITBUCKET_REPO_SLUG=tu-repo-default

# Paths (optional)
DB_PATH=./data/jarvis.db
SOUL_PATH=./soul.md
