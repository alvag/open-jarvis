# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ALLOWED_USER_IDS=123456789

# LLM Provider: "openrouter" (default) or "codex"
# LLM_PROVIDER=openrouter

# OpenRouter LLM (required when LLM_PROVIDER=openrouter)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL_SIMPLE=deepseek/deepseek-chat-v3-0324
OPENROUTER_MODEL_MODERATE=deepseek/deepseek-v3.2
OPENROUTER_MODEL_COMPLEX=anthropic/claude-sonnet-4.6

# OpenAI Codex (ChatGPT subscription OAuth — requires: npm run auth:codex)
# CODEX_MODEL_SIMPLE=gpt-5.4-mini
# CODEX_MODEL_MODERATE=gpt-5.4
# CODEX_MODEL_COMPLEX=gpt-5.4

# Agent
AGENT_MAX_ITERATIONS=10
SESSION_TIMEOUT_MINUTES=30
SESSION_RETENTION_DAYS=30            # Auto-delete sessions older than N days (default: 30)

# Google Workspace (requires: npm i -g @googleworkspace/cli && gws auth login)
GWS_DRIVE_ENABLED=true
GWS_DRIVE_FOLDER_IDS=              # Comma-separated folder IDs to restrict access (empty = all)
GWS_SHEETS_ENABLED=false
GWS_GMAIL_ENABLED=false
GWS_CALENDAR_ENABLED=false

# Bitbucket Cloud (Atlassian API Token)
BITBUCKET_EMAIL=tu-email@ejemplo.com
BITBUCKET_API_TOKEN=tu-atlassian-api-token
BITBUCKET_WORKSPACE=tu-workspace
BITBUCKET_REPO_SLUG=tu-repo-default

# Web Search (Tavily) — get API key at https://tavily.com
TAVILY_API_KEY=tvly-...

# Web Scraping (Firecrawl) — get API key at https://firecrawl.dev
FIRECRAWL_API_KEY=fc-...

# Voice Transcription (Groq Whisper) — https://console.groq.com
# GROQ_API_KEY=gsk_...
# TRANSCRIPTION_LANGUAGE=es

# Paths (optional)
DB_PATH=./data/jarvis.db
SOUL_PATH=./soul.md

ATLASSIAN_USER_EMAIL=
ATLASSIAN_API_TOKEN=

# --- Scheduler ---
# SCHEDULER_TIMEZONE=America/Bogota          # IANA timezone for cron jobs (default: system timezone)
# BRIEFING_TIME=07:00                        # Morning briefing time in HH:MM format (default: 07:00)
# BRIEFING_ENABLED=true                      # Enable morning briefing (default: true)
# PR_POLL_INTERVAL_MINUTES=15                # Bitbucket PR check interval (default: 15)
# PR_MONITOR_ENABLED=true                    # Enable PR monitoring (default: true)

# --- Codebase Analysis ---
# CODEBASE_ENABLED=true                         # Enable code reading tools (default: true)
# CODEBASE_ROOT=./                              # Root directory for code analysis (default: cwd)
# CODEBASE_MAX_FILE_SIZE=102400                 # Max file size in bytes to read (default: 100KB)
# CODEBASE_MAX_OUTPUT=6000                      # Max chars per tool output (default: 6000)
# CODEBASE_IGNORE=node_modules,.git,dist,data,.env,*.db,codex-tokens.json,mcp_config.json

# --- Workflow (worktree + GitHub PRs) ---
# WORKFLOW_ENABLED=false                       # Enable workflow tools: git worktree + GitHub PRs (default: false)
# WORKFLOW_DEFAULT_BRANCH=main                 # Base branch for worktrees (default: main)
# WORKFLOW_WORKTREES_DIR=.worktrees            # Directory for worktrees (default: .worktrees)
# WORKFLOW_BRANCH_PREFIX=jarvis                # Branch name prefix (default: jarvis)
# WORKFLOW_VALIDATION_COMMANDS=npm run lint,npm run test,npm run build  # Comma-separated validation commands
# WORKFLOW_AUTO_CLEANUP_WORKTREE=true          # Auto-remove worktree after PR creation (default: true)

# --- Proactive Code Review ---
# CODE_REVIEW_ENABLED=false                    # Enable automated code review (default: false)
# CODE_REVIEW_TIMES=14:00                      # Review time(s) HH:MM, comma-separated (default: 14:00)
# CODE_REVIEW_MAX_BACKLOG_FILES=3              # Max extra files beyond git-changed per run (default: 3)

# --- Command Safety ---
# EXTRA_SAFE_COMMANDS=npm,npx,node          # Additional commands to auto-approve (default: none)
# Note: When WORKFLOW_ENABLED=true, base executables from WORKFLOW_VALIDATION_COMMANDS
# are automatically added (e.g. "npm run lint" adds "npm" to safe commands).

# --- Tool Manifest & MCP Config ---
# MANIFEST_PATH=./tool_manifest.json          # Path to tool manifest (default: ./tool_manifest.json)
# MCP_CONFIG_PATH=./mcp_config.json           # Path to MCP server config (default: ./mcp_config.json)
