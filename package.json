{
  "name": "open-jarvis",
  "version": "1.9.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --import tsx src/supervisor.ts",
    "start:bg": "nohup node --import tsx src/supervisor.ts > /tmp/jarvis.log 2>&1 & echo $! > .pid && echo \"Jarvis started (PID: $(cat .pid))\"",
    "stop": "if [ -f .pid ] && kill -0 $(cat .pid) 2>/dev/null; then kill $(cat .pid) && rm -f .pid && echo 'Jarvis stopped'; else rm -f .pid && echo 'Not running'; fi",
    "start:bot": "node --import tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "auth:codex": "tsx src/llm/codex-auth-cli.ts"
  },
  "dependencies": {
    "@mendable/firecrawl-js": "^4.16.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@napi-rs/canvas": "^0.1.96",
    "@secretlint/node": "^11.7.1",
    "@secretlint/secretlint-rule-preset-recommend": "^11.7.1",
    "@tavily/core": "^0.7.2",
    "better-sqlite3": "^12.6.2",
    "croner": "^10.0.1",
    "dotenv": "^16.4.7",
    "grammy": "^1.35.0",
    "groq-sdk": "^1.1.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  }
}
